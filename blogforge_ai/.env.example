# LLM provider
GROQ_API_KEY=your_groq_api_key_here
PLANNER_MODEL=groq/llama-3.3-70b-versatile
WRITER_MODEL=groq/openai/gpt-oss-20b
EDITOR_MODEL=groq/openai/gpt-oss-20b

# Web search tool used by the planner/research agent
SERPER_API_KEY=your_serper_api_key_here

# Hugging Face image generation
HF_TOKEN=your_huggingface_token_here
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Optional: if you host generated images publicly, set this for DEV.to cover_image URLs
IMAGE_PUBLIC_BASE_URL=

# DEV.to posting
DEVTO_API_KEY=your_devto_api_key_here
DEVTO_PUBLISH=false
DEVTO_ORGANIZATION_ID=

# App
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_PATH=blogforge.sqlite3
OUTPUT_DIR=outputs
